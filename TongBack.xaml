<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TongBack v2.0"
        Height="740" Width="1060" MinHeight="600" MinWidth="800"
        Background="#0d1117"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Style Label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#8b949e"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,10,0,4"/>
        </Style>

        <!-- Style TextBox sombre -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#0d1117"/>
            <Setter Property="Foreground"               Value="#e6edf3"/>
            <Setter Property="CaretBrush"               Value="#58a6ff"/>
            <Setter Property="BorderBrush"              Value="#30363d"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="8,5"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="FontFamily"               Value="Cascadia Code, Consolas, Courier New"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#388bfd"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style ComboBox sombre -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#0d1117"/>
            <Setter Property="Foreground"      Value="#e6edf3"/>
            <Setter Property="BorderBrush"     Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <!-- Style RadioButton -->
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#e6edf3"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,2,0,2"/>
        </Style>

        <!-- Bouton principal (vert) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#238636"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2ea043"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#21262d"/>
                                <Setter Property="Foreground" Value="#8b949e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton danger (rouge) -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background"      Value="#b62324"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#da3633"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#21262d"/>
                                <Setter Property="Foreground" Value="#8b949e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton secondaire -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#21262d"/>
            <Setter Property="Foreground"      Value="#e6edf3"/>
            <Setter Property="BorderBrush"     Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363d"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8b949e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8b949e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#58a6ff"/>
                                <Setter Property="Foreground" Value="#58a6ff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#e6edf3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Margin"     Value="0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ═══ EN-TÊTE ═══ -->
        <Border Grid.Row="0" Background="#161b22"
                BorderBrush="#21262d" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TongBack" FontSize="22" FontWeight="Bold"
                               Foreground="#58a6ff" VerticalAlignment="Center"/>
                    <TextBlock Text=" v2.0" FontSize="13" Foreground="#8b949e"
                               VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                    <Rectangle Width="1" Fill="#30363d" Margin="12,10"/>
                    <TextBlock Text="Hashcat + John the Ripper Wrapper"
                               FontSize="12" Foreground="#8b949e" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Auteur : Othmane AZIRAR" FontSize="11" Foreground="#8b949e"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ ONGLETS ═══ -->
        <TabControl Grid.Row="1" Background="#0d1117" BorderThickness="0" Padding="0">

            <!-- ── ATTAQUE ── -->
            <TabItem Header="⚔  Attaque">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" MinWidth="280" MaxWidth="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Gauche : paramètres -->
                    <Border Grid.Column="0" Background="#0d1117"
                            BorderBrush="#21262d" BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="16,12,16,16">

                                <TextBlock Text="MODE D'ATTAQUE" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cbMode" Style="{StaticResource DarkComboBox}"/>

                                <TextBlock Text="HASH MODE  (-m)" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="tbHashMode" Style="{StaticResource DarkTextBox}"
                                             ToolTip="Ex: 1000 = NTLM, 0 = MD5, 10400 = PDF"/>
                                    <Button x:Name="btnSearchHashMode" Content="🔍"
                                            Style="{StaticResource SecondaryBtn}"
                                            Margin="4,0,0,0" Width="34"
                                            ToolTip="Aller dans l'onglet Recherche"/>
                                </Grid>

                                <Separator/>

                                <TextBlock Text="SOURCE DU HASH" Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,6"/>

                                <RadioButton x:Name="rbDirectHash" Content="Hash direct"
                                             Style="{StaticResource DarkRadio}" IsChecked="True"/>
                                <TextBox x:Name="tbHash" Style="{StaticResource DarkTextBox}"
                                         Margin="0,4,0,8"
                                         ToolTip="Coller la valeur brute du hash"/>

                                <RadioButton x:Name="rbFromFile" Content="Depuis un fichier (auto)"
                                             Style="{StaticResource DarkRadio}"/>
                                <Grid x:Name="pnlFile" Margin="0,4,0,0" IsEnabled="False">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="tbFile" Style="{StaticResource DarkTextBox}"
                                             IsReadOnly="True"
                                             ToolTip="Hash extrait automatiquement via John"/>
                                    <Button x:Name="btnBrowseFile" Content="📂"
                                            Style="{StaticResource SecondaryBtn}"
                                            Margin="4,0,0,0" Width="34"/>
                                </Grid>

                                <Separator/>

                                <StackPanel x:Name="pnlWordlists">
                                    <TextBlock Text="WORDLIST" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="tbWordlist1"
                                                 Style="{StaticResource DarkTextBox}"
                                                 IsReadOnly="True"/>
                                        <Button x:Name="btnBrowseWl1" Content="📂"
                                                Style="{StaticResource SecondaryBtn}"
                                                Margin="4,0,0,0" Width="34"/>
                                    </Grid>
                                    <StackPanel x:Name="pnlWordlist2" Visibility="Collapsed">
                                        <TextBlock Text="WORDLIST 2  (mode 1)"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="tbWordlist2"
                                                     Style="{StaticResource DarkTextBox}"
                                                     IsReadOnly="True"/>
                                            <Button x:Name="btnBrowseWl2" Content="📂"
                                                    Style="{StaticResource SecondaryBtn}"
                                                    Margin="4,0,0,0" Width="34"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel x:Name="pnlMask" Visibility="Collapsed">
                                    <TextBlock Text="MASQUE" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="tbMask" Style="{StaticResource DarkTextBox}"
                                             ToolTip="Ex: ?u?l?l?l?d?d?d?d"/>
                                    <TextBlock Foreground="#8b949e" FontSize="10" Margin="0,3,0,0"
                                               Text="?l=min  ?u=MAJ  ?d=chiffres  ?s=spéciaux  ?a=tout"/>
                                </StackPanel>

                                <Separator/>

                                <TextBlock Text="ARGUMENTS SUPPLÉMENTAIRES"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="tbExtraArgs" Style="{StaticResource DarkTextBox}"
                                         ToolTip="Ex: --force --optimized-kernel-enable"/>

                                <Separator/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnStart" Content="▶  Lancer"
                                            Style="{StaticResource PrimaryBtn}"
                                            Grid.Column="0" Margin="0,0,4,0" Height="34"/>
                                    <Button x:Name="btnStop" Content="■  Arrêter"
                                            Style="{StaticResource DangerBtn}"
                                            Grid.Column="1" Margin="4,0,0,0"
                                            IsEnabled="False" Height="34"/>
                                </Grid>
                                <Button x:Name="btnClear" Content="🗑  Effacer la sortie"
                                        Style="{StaticResource SecondaryBtn}"
                                        Margin="0,6,0,0" Height="28"/>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Droite : sortie console -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#161b22"
                                BorderBrush="#21262d" BorderThickness="0,0,0,1">
                            <TextBlock Text="SORTIE CONSOLE"
                                       Foreground="#8b949e" FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="12,0"/>
                        </Border>
                        <TextBox x:Name="tbOutput" Grid.Row="1"
                                 Background="#0d1117" Foreground="#39d353"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="12" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 BorderThickness="0" Padding="12,10"
                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── RECHERCHE ── -->
            <TabItem Header="🔍  Recherche">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#161b22"
                            BorderBrush="#21262d" BorderThickness="0,0,0,1" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="tbSearch" Style="{StaticResource DarkTextBox}"
                                     ToolTip="Recherche regex : md5, sha1, ntlm, pdf, kerberos..."/>
                            <Button x:Name="btnSearch" Content="🔍  Rechercher"
                                    Style="{StaticResource PrimaryBtn}"
                                    Grid.Column="1" Margin="8,0,0,0" Height="32"/>
                        </Grid>
                    </Border>
                    <TextBox x:Name="tbSearchResults" Grid.Row="1"
                             Background="#0d1117" Foreground="#e6edf3"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             BorderThickness="0" Padding="16,12"
                             TextWrapping="Wrap" AcceptsReturn="True"/>
                </Grid>
            </TabItem>

            <!-- ── À PROPOS ── -->
            <TabItem Header="ℹ  À propos">
                <ScrollViewer Background="#0d1117" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40,30" MaxWidth="620" HorizontalAlignment="Center">
                        <TextBlock Text="TongBack" FontSize="42" FontWeight="Bold"
                                   Foreground="#58a6ff" HorizontalAlignment="Center"/>
                        <TextBlock Text="v2.0.0" FontSize="16" Foreground="#8b949e"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Hashcat + John the Ripper Wrapper" FontSize="14"
                                   Foreground="#8b949e" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <Separator/>
                        <TextBlock TextWrapping="Wrap" Foreground="#e6edf3" FontSize="13"
                                   LineHeight="22" Margin="0,16,0,16">
Ce module PowerShell simplifie l'utilisation de Hashcat et John the Ripper.
Il permet de rechercher des formats de hash, d'extraire automatiquement des hashes
depuis des fichiers protégés (.pdf, .zip, .docx, .kdbx…) et de lancer des attaques
par dictionnaire, combinaison, masque ou hybride.
                        </TextBlock>
                        <Separator/>
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Auteur" Foreground="#8b949e" FontSize="11" Margin="0,0,0,3"/>
                                <TextBlock Text="Othmane AZIRAR" Foreground="#e6edf3" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Version" Foreground="#8b949e" FontSize="11" Margin="0,0,0,3"/>
                                <TextBlock Text="2.0.0" Foreground="#e6edf3" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PowerShell" Foreground="#8b949e" FontSize="11" Margin="0,0,0,3"/>
                                <TextBlock Text="5.1+" Foreground="#e6edf3" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                        <Separator Margin="0,16"/>
                        <TextBlock Text="Modes d'attaque" Foreground="#58a6ff"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="0" Foreground="#58a6ff" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Dictionnaire" Foreground="#e6edf3" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="1" Foreground="#58a6ff" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Combinaison (Wordlist × Wordlist)" Foreground="#e6edf3" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="3" Foreground="#58a6ff" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Brute-force masque" Foreground="#e6edf3" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="6" Foreground="#58a6ff" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Hybride (Wordlist + Masque)" Foreground="#e6edf3" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="7" Foreground="#58a6ff" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Hybride (Masque + Wordlist)" Foreground="#e6edf3"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ═══ BARRE DE STATUT ═══ -->
        <Border Grid.Row="2" Background="#161b22"
                BorderBrush="#21262d" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="statusDot" Width="7" Height="7"
                             Fill="#3fb950" Margin="0,0,7,0"/>
                    <TextBlock x:Name="tbStatus" Text="Prêt"
                               Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="TongBack v2.0" HorizontalAlignment="Right"
                           Foreground="#30363d" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
