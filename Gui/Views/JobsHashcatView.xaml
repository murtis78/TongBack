<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0d1117">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panneau gauche : parametres -->
        <Border Grid.Column="0" Background="#161b22"
                BorderBrush="#30363d" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,20,20,20">
                    <TextBlock Text="Job Hashcat" FontSize="18" FontWeight="SemiBold"
                               Foreground="#e6edf3" Margin="0,0,0,20"/>

                    <!-- Mode -->
                    <TextBlock Text="Mode d'attaque" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbHcMode" Background="#21262d" Foreground="#e6edf3"
                              BorderBrush="#30363d" BorderThickness="1" Padding="8,6" Margin="0,0,0,14">
                        <ComboBoxItem Content="0 - Dictionnaire"   Tag="0" IsSelected="True"/>
                        <ComboBoxItem Content="1 - Combinaison"    Tag="1"/>
                        <ComboBoxItem Content="3 - Masque"         Tag="3"/>
                        <ComboBoxItem Content="6 - Hybride wl+mask" Tag="6"/>
                        <ComboBoxItem Content="7 - Hybride mask+wl" Tag="7"/>
                    </ComboBox>

                    <!-- HashMode -->
                    <TextBlock Text="Mode hash (-m)" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#21262d" BorderBrush="#30363d"
                                BorderThickness="1" CornerRadius="6,0,0,6">
                            <TextBox x:Name="tbHcHashMode" Background="Transparent"
                                     Foreground="#e6edf3" CaretBrush="#58a6ff"
                                     BorderThickness="0" Padding="10,7" Text="10400"/>
                        </Border>
                        <Button x:Name="btnHcFindMode" Grid.Column="1" Content="?"
                                Background="#30363d" Foreground="#8b949e"
                                BorderBrush="#30363d" BorderThickness="1,1,1,1"
                                Padding="10,7" Cursor="Hand" ToolTip="Rechercher un mode">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="0,6,6,0" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#58a6ff"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Source du hash -->
                    <TextBlock Text="Source du hash" Foreground="#8b949e" FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="rbHcDirectHash" Content="Hash direct"
                                     Foreground="#e6edf3" IsChecked="True" Margin="0,0,16,0"/>
                        <RadioButton x:Name="rbHcFromFile" Content="Depuis fichier"
                                     Foreground="#e6edf3"/>
                    </StackPanel>

                    <!-- Hash direct -->
                    <Border x:Name="pnlHcHash" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Hash" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#21262d" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6">
                                <TextBox x:Name="tbHcHash" Background="Transparent" Foreground="#e6edf3"
                                         CaretBrush="#58a6ff" BorderThickness="0" Padding="10,7"
                                         FontFamily="Consolas" FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Depuis fichier -->
                    <Border x:Name="pnlHcFile" Visibility="Collapsed" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Fichier" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#21262d" BorderBrush="#30363d"
                                        BorderThickness="1" CornerRadius="6,0,0,6">
                                    <TextBox x:Name="tbHcFile" Background="Transparent"
                                             Foreground="#e6edf3" CaretBrush="#58a6ff"
                                             BorderThickness="0" Padding="10,7"/>
                                </Border>
                                <Button x:Name="btnHcBrowseFile" Grid.Column="1" Content="..."
                                        Background="#30363d" Foreground="#e6edf3"
                                        BorderBrush="#30363d" BorderThickness="1"
                                        Padding="10,7" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="0,6,6,0" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#58a6ff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Wordlist(s) -->
                    <Border x:Name="pnlHcWordlists" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Wordlist" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#21262d" BorderBrush="#30363d"
                                        BorderThickness="1" CornerRadius="6,0,0,6">
                                    <TextBox x:Name="tbHcWordlist1" Background="Transparent"
                                             Foreground="#e6edf3" CaretBrush="#58a6ff"
                                             BorderThickness="0" Padding="10,7"/>
                                </Border>
                                <Button x:Name="btnHcBrowseWl1" Grid.Column="1" Content="..."
                                        Background="#30363d" Foreground="#e6edf3"
                                        BorderBrush="#30363d" BorderThickness="1"
                                        Padding="10,7" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="0,6,6,0" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#58a6ff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- 2eme wordlist mode 1 -->
                            <Border x:Name="pnlHcWordlist2" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#21262d" BorderBrush="#30363d"
                                            BorderThickness="1" CornerRadius="6,0,0,6">
                                        <TextBox x:Name="tbHcWordlist2" Background="Transparent"
                                                 Foreground="#e6edf3" CaretBrush="#58a6ff"
                                                 BorderThickness="0" Padding="10,7"/>
                                    </Border>
                                    <Button x:Name="btnHcBrowseWl2" Grid.Column="1" Content="..."
                                            Background="#30363d" Foreground="#e6edf3"
                                            BorderBrush="#30363d" BorderThickness="1"
                                            Padding="10,7" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="0,6,6,0" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#58a6ff"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Masque -->
                    <Border x:Name="pnlHcMask" Visibility="Collapsed" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Masque" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#21262d" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6">
                                <TextBox x:Name="tbHcMask" Background="Transparent" Foreground="#e6edf3"
                                         CaretBrush="#58a6ff" BorderThickness="0" Padding="10,7"
                                         FontFamily="Consolas" Text="?a?a?a?a?a?a?a?a"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Boutons action -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnHcStart" Grid.Column="0" Content="Lancer"
                                Background="#238636" Foreground="White"
                                BorderBrush="#2ea043" BorderThickness="1"
                                Padding="0,10" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2ea043"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnHcStop" Grid.Column="1" Content="Arreter"
                                Background="#21262d" Foreground="#f85149"
                                BorderBrush="#30363d" BorderThickness="1"
                                Padding="14,10" Cursor="Hand" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Panneau droit : console output -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#161b22" Padding="16,10">
                <Grid>
                    <TextBlock Text="Sortie hashcat" Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                    <Button x:Name="btnHcClear" Content="Effacer" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="#8b949e"
                            BorderBrush="Transparent" BorderThickness="0"
                            Padding="8,4" Cursor="Hand" FontSize="11"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#0d1117" Padding="2">
                <ScrollViewer x:Name="svHcOutput" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="tbHcOutput" Background="Transparent"
                             Foreground="#39d353" CaretBrush="#39d353"
                             BorderThickness="0" Padding="16"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True" TextWrapping="NoWrap"
                             AcceptsReturn="True"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
