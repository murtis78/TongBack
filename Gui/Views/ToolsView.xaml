<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0d1117">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Outils" FontSize="22" FontWeight="SemiBold" Foreground="#e6edf3"/>
            <TextBlock Text="Gestion de hashcat et John the Ripper"
                       Foreground="#8b949e" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Liste des outils detectes -->
        <Border Grid.Row="1" Background="#161b22" CornerRadius="8"
                BorderBrush="#30363d" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#21262d" CornerRadius="8,8,0,0" Padding="16,10">
                    <TextBlock Text="Outils detectes dans Tools/" Foreground="#8b949e" FontSize="12"/>
                </Border>

                <DataGrid x:Name="dgTools" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="#e6edf3"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#21262d" RowBackground="#161b22"
                          AlternatingRowBackground="#161b22" CanUserAddRows="False"
                          HeadersVisibility="Column" IsReadOnly="True" Margin="0">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#21262d"/>
                            <Setter Property="Foreground" Value="#8b949e"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="BorderBrush" Value="#30363d"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Outil"      Binding="{Binding Name}"        Width="100"/>
                        <DataGridTextColumn Header="Version"    Binding="{Binding Version}"     Width="150"/>
                        <DataGridTextColumn Header="Chemin"     Binding="{Binding ExePath}"     Width="*"/>
                        <DataGridCheckBoxColumn Header="Actif"  Binding="{Binding IsActive}"    Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnSetActive" Content="Definir comme actif"
                    Background="#21262d" Foreground="#e6edf3"
                    BorderBrush="#30363d" BorderThickness="1"
                    Padding="14,8" Margin="0,0,8,0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="btnRefreshTools" Content="Actualiser"
                    Background="#21262d" Foreground="#e6edf3"
                    BorderBrush="#30363d" BorderThickness="1"
                    Padding="14,8" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
