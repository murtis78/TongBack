<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0d1117">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Formats de hash" FontSize="22" FontWeight="SemiBold" Foreground="#e6edf3"/>
            <TextBlock Text="Recherchez dans les modes Hashcat et formats John the Ripper"
                       Foreground="#8b949e" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Barre de recherche -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#161b22" BorderBrush="#30363d"
                    BorderThickness="1" CornerRadius="6" Margin="0,0,8,0">
                <TextBox x:Name="tbFormatSearch" Background="Transparent"
                         Foreground="#e6edf3" CaretBrush="#58a6ff"
                         BorderThickness="0" Padding="12,8"
                         FontSize="13" VerticalAlignment="Center"
                         Text="Rechercher (ex: pdf, ntlm, md5...)"/>
            </Border>

            <Button x:Name="btnFormatSearch" Grid.Column="1" Content="Rechercher"
                    Background="#238636" Foreground="White"
                    BorderBrush="#2ea043" BorderThickness="1"
                    Padding="16,8" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2ea043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Resultats en onglets Hashcat / John -->
        <TabControl Grid.Row="2" Background="#161b22"
                    BorderBrush="#30363d" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background"  Value="#161b22"/>
                    <Setter Property="Foreground"  Value="#8b949e"/>
                    <Setter Property="Padding"     Value="14,8"/>
                    <Setter Property="BorderBrush" Value="#30363d"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#21262d"/>
                            <Setter Property="Foreground" Value="#e6edf3"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Hashcat">
                <DataGrid x:Name="dgHashcatModes" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="#e6edf3"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#21262d" RowBackground="#161b22"
                          AlternatingRowBackground="#1c2128" CanUserAddRows="False"
                          HeadersVisibility="Column" IsReadOnly="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"    Value="#21262d"/>
                            <Setter Property="Foreground"    Value="#8b949e"/>
                            <Setter Property="Padding"       Value="12,6"/>
                            <Setter Property="FontSize"      Value="11"/>
                            <Setter Property="BorderBrush"   Value="#30363d"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="-m"    Binding="{Binding Mode}"     Width="70"/>
                        <DataGridTextColumn Header="Nom"   Binding="{Binding Name}"     Width="*"/>
                        <DataGridTextColumn Header="Categorie" Binding="{Binding Category}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="John the Ripper">
                <ListBox x:Name="lbJohnFormats"
                         Background="Transparent" Foreground="#e6edf3"
                         BorderThickness="0" FontSize="13">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="12,4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
