<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0d1117">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Sessions" FontSize="22" FontWeight="SemiBold" Foreground="#e6edf3"/>
            <TextBlock Text="Historique et gestion des jobs"
                       Foreground="#8b949e" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#161b22" CornerRadius="8"
                BorderBrush="#30363d" BorderThickness="1">
            <DockPanel>
                <!-- Filtres -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Background="#21262d" Margin="0" >
                    <TextBlock Text="Filtrer : " Foreground="#8b949e" FontSize="11"
                               VerticalAlignment="Center" Margin="12,8,6,8"/>
                    <ComboBox x:Name="cbSessionFilter" Background="#30363d" Foreground="#e6edf3"
                              BorderBrush="#30363d" BorderThickness="1" Padding="8,4"
                              MinWidth="120" Margin="0,6,0,6">
                        <ComboBoxItem Content="Tous" IsSelected="True"/>
                        <ComboBoxItem Content="Running"/>
                        <ComboBoxItem Content="Completed"/>
                        <ComboBoxItem Content="Failed"/>
                        <ComboBoxItem Content="Cancelled"/>
                        <ComboBoxItem Content="Paused"/>
                    </ComboBox>
                    <Button x:Name="btnSessionRefresh" Content="Actualiser"
                            Background="#21262d" Foreground="#8b949e"
                            BorderBrush="#30363d" BorderThickness="1"
                            Padding="10,4" Cursor="Hand" Margin="8,6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                        <Setter Property="Foreground" Value="#e6edf3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <DataGrid x:Name="dgSessions" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="#e6edf3"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#21262d" RowBackground="#161b22"
                          AlternatingRowBackground="#1c2128" CanUserAddRows="False"
                          HeadersVisibility="Column" SelectionMode="Single">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"    Value="#21262d"/>
                            <Setter Property="Foreground"    Value="#8b949e"/>
                            <Setter Property="Padding"       Value="12,6"/>
                            <Setter Property="FontSize"      Value="11"/>
                            <Setter Property="BorderBrush"   Value="#30363d"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"       Binding="{Binding Id}"        Width="250"/>
                        <DataGridTextColumn Header="Outil"    Binding="{Binding Tool}"       Width="80"/>
                        <DataGridTextColumn Header="Mode"     Binding="{Binding Mode}"       Width="50"/>
                        <DataGridTextColumn Header="HashMode" Binding="{Binding HashMode}"   Width="80"/>
                        <DataGridTextColumn Header="Statut"   Binding="{Binding Status}"     Width="100"/>
                        <DataGridTextColumn Header="Debut"    Binding="{Binding StartTime}"  Width="160"/>
                        <DataGridTextColumn Header="Fin"      Binding="{Binding EndTime}"    Width="160"/>
                        <DataGridTextColumn Header="Code"     Binding="{Binding ExitCode}"   Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnResumeJob" Content="Reprendre"
                    Background="#21262d" Foreground="#58a6ff"
                    BorderBrush="#30363d" BorderThickness="1"
                    Padding="14,8" Margin="0,0,8,0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="btnStopJob" Content="Arreter"
                    Background="#21262d" Foreground="#f85149"
                    BorderBrush="#30363d" BorderThickness="1"
                    Padding="14,8" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#f85149"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
