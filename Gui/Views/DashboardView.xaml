<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0d1117">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="22" FontWeight="SemiBold"
                       Foreground="#e6edf3" Margin="0,0,0,20"/>

            <!-- Cartes de statut -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Hashcat -->
                <Border Grid.Column="0" Background="#161b22" CornerRadius="8"
                        BorderBrush="#30363d" BorderThickness="1" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Hashcat" Foreground="#8b949e" FontSize="12"/>
                        <TextBlock x:Name="tbHashcatStatus" Text="..." FontSize="16"
                                   FontWeight="SemiBold" Foreground="#58a6ff" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- John -->
                <Border Grid.Column="1" Background="#161b22" CornerRadius="8"
                        BorderBrush="#30363d" BorderThickness="1" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="John the Ripper" Foreground="#8b949e" FontSize="12"/>
                        <TextBlock x:Name="tbJohnStatus" Text="..." FontSize="16"
                                   FontWeight="SemiBold" Foreground="#58a6ff" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Jobs actifs -->
                <Border Grid.Column="2" Background="#161b22" CornerRadius="8"
                        BorderBrush="#30363d" BorderThickness="1" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Jobs actifs" Foreground="#8b949e" FontSize="12"/>
                        <TextBlock x:Name="tbActiveJobs" Text="0" FontSize="16"
                                   FontWeight="SemiBold" Foreground="#39d353" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Resultats -->
                <Border Grid.Column="3" Background="#161b22" CornerRadius="8"
                        BorderBrush="#30363d" BorderThickness="1" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Mots de passe" Foreground="#8b949e" FontSize="12"/>
                        <TextBlock x:Name="tbResultCount" Text="0" FontSize="16"
                                   FontWeight="SemiBold" Foreground="#e3b341" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Derniers jobs -->
            <TextBlock Text="Derniers jobs" FontSize="15" FontWeight="SemiBold"
                       Foreground="#e6edf3" Margin="0,0,0,10"/>

            <Border Background="#161b22" CornerRadius="8" BorderBrush="#30363d" BorderThickness="1">
                <DataGrid x:Name="dgRecentJobs" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="#e6edf3"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#21262d" RowBackground="#161b22"
                          AlternatingRowBackground="#161b22" CanUserAddRows="False"
                          HeadersVisibility="Column" IsReadOnly="True"
                          MaxHeight="200" Margin="0">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#21262d"/>
                            <Setter Property="Foreground" Value="#8b949e"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="BorderBrush" Value="#30363d"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       Width="250"/>
                        <DataGridTextColumn Header="Outil"    Binding="{Binding Tool}"      Width="80"/>
                        <DataGridTextColumn Header="Mode"     Binding="{Binding Mode}"      Width="50"/>
                        <DataGridTextColumn Header="HashMode" Binding="{Binding HashMode}"  Width="80"/>
                        <DataGridTextColumn Header="Statut"   Binding="{Binding Status}"    Width="100"/>
                        <DataGridTextColumn Header="Debut"    Binding="{Binding StartTime}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Derniers resultats -->
            <TextBlock Text="Derniers resultats" FontSize="15" FontWeight="SemiBold"
                       Foreground="#e6edf3" Margin="0,20,0,10"/>

            <Border Background="#161b22" CornerRadius="8" BorderBrush="#30363d" BorderThickness="1">
                <DataGrid x:Name="dgRecentResults" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="#e6edf3"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#21262d" RowBackground="#161b22"
                          AlternatingRowBackground="#161b22" CanUserAddRows="False"
                          HeadersVisibility="Column" IsReadOnly="True"
                          MaxHeight="150" Margin="0">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#21262d"/>
                            <Setter Property="Foreground" Value="#8b949e"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="BorderBrush" Value="#30363d"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="JobId"       Binding="{Binding JobId}"    Width="250"/>
                        <DataGridTextColumn Header="Hash"        Binding="{Binding Hash}"     Width="200"/>
                        <DataGridTextColumn Header="Mot de passe" Binding="{Binding Password}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
