<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0d1117">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panneau gauche : constructeur -->
        <Border Grid.Column="0" Background="#161b22"
                BorderBrush="#30363d" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,20,20,20">
                    <TextBlock Text="Mode Expert" FontSize="18" FontWeight="SemiBold"
                               Foreground="#e6edf3" Margin="0,0,0,4"/>
                    <TextBlock Text="Construisez votre commande hashcat manuellement"
                               Foreground="#8b949e" FontSize="11" TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <!-- Outil -->
                    <TextBlock Text="Outil" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbExpertTool" Background="#21262d" Foreground="#e6edf3"
                              BorderBrush="#30363d" BorderThickness="1" Padding="8,6" Margin="0,0,0,14">
                        <ComboBoxItem Content="hashcat" IsSelected="True"/>
                        <ComboBoxItem Content="john"/>
                    </ComboBox>

                    <!-- Mode -->
                    <TextBlock Text="Mode d'attaque (-a)" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#21262d" BorderBrush="#30363d" BorderThickness="1"
                            CornerRadius="6" Margin="0,0,0,14">
                        <TextBox x:Name="tbExpertMode" Background="Transparent"
                                 Foreground="#e6edf3" CaretBrush="#58a6ff"
                                 BorderThickness="0" Padding="10,7" Text="0"/>
                    </Border>

                    <!-- HashMode -->
                    <TextBlock Text="Mode hash (-m)" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#21262d" BorderBrush="#30363d" BorderThickness="1"
                            CornerRadius="6" Margin="0,0,0,14">
                        <TextBox x:Name="tbExpertHashMode" Background="Transparent"
                                 Foreground="#e6edf3" CaretBrush="#58a6ff"
                                 BorderThickness="0" Padding="10,7" Text="0"/>
                    </Border>

                    <!-- Hash -->
                    <TextBlock Text="Hash / Fichier hash" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#21262d" BorderBrush="#30363d" BorderThickness="1"
                            CornerRadius="6" Margin="0,0,0,14">
                        <TextBox x:Name="tbExpertHash" Background="Transparent"
                                 Foreground="#e6edf3" CaretBrush="#58a6ff"
                                 BorderThickness="0" Padding="10,7"
                                 FontFamily="Consolas" FontSize="12"/>
                    </Border>

                    <!-- Arguments libres -->
                    <TextBlock Text="Arguments supplementaires" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#21262d" BorderBrush="#30363d" BorderThickness="1"
                            CornerRadius="6" Margin="0,0,0,6">
                        <TextBox x:Name="tbExpertArgs" Background="Transparent"
                                 Foreground="#e6edf3" CaretBrush="#58a6ff"
                                 BorderThickness="0" Padding="10,7"
                                 FontFamily="Consolas" FontSize="12"
                                 Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                    <TextBlock Text="Ex : rockyou.txt --username --outfile results.txt"
                               Foreground="#8b949e" FontSize="10" Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <!-- Preview commande -->
                    <TextBlock Text="Commande construite" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#0d1117" BorderBrush="#30363d" BorderThickness="1"
                            CornerRadius="6" Margin="0,0,0,20">
                        <TextBox x:Name="tbExpertPreview" Background="Transparent"
                                 Foreground="#e3b341" CaretBrush="#e3b341"
                                 BorderThickness="0" Padding="10,7"
                                 FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 Height="60"/>
                    </Border>

                    <!-- Boutons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnExpertRun" Grid.Column="0" Content="Executer"
                                Background="#238636" Foreground="White"
                                BorderBrush="#2ea043" BorderThickness="1"
                                Padding="0,10" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2ea043"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnExpertStop" Grid.Column="1" Content="Stop"
                                Background="#21262d" Foreground="#f85149"
                                BorderBrush="#30363d" BorderThickness="1"
                                Padding="14,10" Cursor="Hand" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Console output -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#161b22" Padding="16,10">
                <Grid>
                    <TextBlock Text="Sortie" Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                    <Button x:Name="btnExpertClear" Content="Effacer" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="#8b949e"
                            BorderBrush="Transparent" BorderThickness="0"
                            Padding="8,4" Cursor="Hand" FontSize="11"/>
                </Grid>
            </Border>
            <Border Grid.Row="1" Background="#0d1117" Padding="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="tbExpertOutput" Background="Transparent"
                             Foreground="#39d353" CaretBrush="#39d353"
                             BorderThickness="0" Padding="16"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
