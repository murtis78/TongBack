<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="MainWindow"
    Title="TongBack v3.0 — Hashcat + John the Ripper"
    Width="1100" Height="720"
    MinWidth="900" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="#0d1117">

    <Window.Resources>
        <!-- Couleurs GitHub Dark -->
        <SolidColorBrush x:Key="BgPrimary"    Color="#0d1117"/>
        <SolidColorBrush x:Key="BgSecondary"  Color="#161b22"/>
        <SolidColorBrush x:Key="BgTertiary"   Color="#21262d"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#30363d"/>
        <SolidColorBrush x:Key="Accent"       Color="#58a6ff"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#39d353"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#f85149"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#e3b341"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#e6edf3"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#8b949e"/>

        <!-- Style bouton sidebar -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="#8b949e"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="16,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Margin="6,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#21262d"/>
                                <Setter Property="Foreground" Value="#e6edf3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton sidebar actif -->
        <Style x:Key="SidebarButtonActive" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background"  Value="#21262d"/>
            <Setter Property="Foreground"  Value="#58a6ff"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar gauche -->
        <Border Grid.Column="0" Background="#161b22"
                BorderBrush="#30363d" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo / titre -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,16">
                    <TextBlock Text="TongBack" FontSize="18" FontWeight="Bold"
                               Foreground="#58a6ff" HorizontalAlignment="Left"/>
                    <TextBlock Text="v3.0" FontSize="11" Foreground="#8b949e" Margin="0,2,0,0"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#30363d" Margin="8,0"/>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <Button x:Name="btnNavDashboard"   Style="{StaticResource SidebarButtonActive}"
                            Content="   Dashboard" Tag="Dashboard"/>
                    <Button x:Name="btnNavTools"        Style="{StaticResource SidebarButton}"
                            Content="   Outils" Tag="Tools"/>
                    <Button x:Name="btnNavFormats"      Style="{StaticResource SidebarButton}"
                            Content="   Formats de hash" Tag="Formats"/>
                    <Button x:Name="btnNavJobsHashcat"  Style="{StaticResource SidebarButton}"
                            Content="   Jobs Hashcat" Tag="JobsHashcat"/>
                    <Button x:Name="btnNavJobsJohn"     Style="{StaticResource SidebarButton}"
                            Content="   Jobs John" Tag="JobsJohn"/>
                    <Button x:Name="btnNavSessions"     Style="{StaticResource SidebarButton}"
                            Content="   Sessions" Tag="Sessions"/>
                    <Button x:Name="btnNavExpert"       Style="{StaticResource SidebarButton}"
                            Content="   Mode Expert" Tag="ModeExpert"/>
                </StackPanel>

                <!-- Bas sidebar : statut -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
                    <Separator Background="#30363d" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="statusDot" Width="8" Height="8"
                                 Fill="#39d353" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="tbStatus" Text="Pret"
                                   Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Zone de contenu principale -->
        <ContentControl x:Name="MainContent" Grid.Column="1"
                        Background="#0d1117"/>
    </Grid>
</Window>
